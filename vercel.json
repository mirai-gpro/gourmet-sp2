{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [],
  "rewrites": [
    {
      "source": "/api/v2/:path*",
      "destination": "${PUBLIC_API_URL}/api/v2/:path*"
    },
    {
      "source": "/api/stt/:path*",
      "destination": "${PUBLIC_API_URL}/api/stt/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "${PUBLIC_API_URL}/socket.io/:path*"
    }
  ]
}
